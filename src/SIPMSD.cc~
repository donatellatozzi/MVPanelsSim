{}

G4bool SIPMSD::ProcessHits(G4Step* aStep, G4TouchableHistory*) {
    
    // Assicuriamoci che sia un fotone ottico
    if (aStep->GetTrack()->GetDefinition() == G4OpticalPhoton::OpticalPhotonDefinition()) {

        G4String name = GetName();
        G4int sipmID = -1;
        auto eventAction = (EventAction*)G4RunManager::GetRunManager()->GetUserEventAction();

        // Mappiamo il nome del sensore all'ID corretto
        if      (name == "SiPM_SD_0") sipmID = 0;
        else if (name == "SiPM_SD_1") sipmID = 1;
        else if (name == "SiPM_SD_2") sipmID = 2;
        else if (name == "SiPM_SD_3") sipmID = 3;
        
        if (sipmID >= 0) {
            auto am = G4AnalysisManager::Instance();
            
            G4double hitTime = aStep->GetPostStepPoint()->GetGlobalTime();
            G4double energy  = aStep->GetTrack()->GetKineticEnergy();
            G4int trackID    = aStep->GetTrack()->GetTrackID();
            G4int evtID      = G4RunManager::GetRunManager()->GetCurrentEvent()->GetEventID();

            // Aggiorniamo i contatori globali in EventAction (Ntuple 0)
            eventAction->AddSiPMHit(sipmID);      // Questo l'avevi commentato, ora è attivo!
            eventAction->RegisterSiPMHit(hitTime);
     
            // Salviamo i dettagli nella Tabella dei Fotoni (Ntuple 1)
            am->FillNtupleIColumn(1, 0, evtID);
            am->FillNtupleIColumn(1, 1, trackID);
            am->FillNtupleDColumn(1, 2, energy/eV); 
            am->FillNtupleDColumn(1, 3, hitTime/ns);
            am->FillNtupleIColumn(1, 4, sipmID);
            am->AddNtupleRow(1);

            // Uccidiamo il fotone
            aStep->GetTrack()->SetTrackStatus(fStopAndKill);
        }
        
        return true;
    }
    return false;
}

